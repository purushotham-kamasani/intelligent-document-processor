# --- Application ---
APP_NAME=intelligent-document-processor
APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/v1

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docs

# --- LLM Client ---
LLM_PROVIDER=mock
LLM_MODEL=mock-gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# --- Storage ---
# Where uploaded files land on disk. In production, swap for S3/GCS.
STORAGE_PATH=./storage/uploads
MAX_UPLOAD_BYTES=10485760  # 10 MB

# --- Batch Processing ---
# Max documents processed in parallel during a batch run.
BATCH_MAX_CONCURRENCY=4
BATCH_DOCUMENT_TIMEOUT_SECONDS=120
